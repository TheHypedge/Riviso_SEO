[Unit]
Description=Auto Articles Backend (FastAPI / Uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/auto-articles/backend
Environment=ENVIRONMENT=production
EnvironmentFile=/var/www/auto-articles/backend/.env
ExecStart=/var/www/auto-articles/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --proxy-headers --forwarded-allow-ips=*
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
