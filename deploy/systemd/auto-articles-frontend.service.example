[Unit]
Description=Auto Articles Frontend (Next.js)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/auto-articles/frontend
Environment=NODE_ENV=production
# Point Next.js rewrite to the local backend (optional when using Nginx /api proxy).
Environment=BACKEND_URL=http://127.0.0.1:8000
ExecStart=/usr/bin/npm run start -- --port 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
