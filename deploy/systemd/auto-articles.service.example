# Copy to /etc/systemd/system/auto-articles.service
# sudo systemctl daemon-reload && sudo systemctl enable --now auto-articles
#
# Adjust paths and User= to match your VM (e.g. /var/www/auto-articles).

[Unit]
Description=Auto Articles (Gunicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/auto-articles
# Gunicorn writes control state under $HOME/.gunicorn; default HOME for www-data is /var/www (not writable).
Environment=HOME=/var/www/auto-articles
Environment=FLASK_ENV=production
EnvironmentFile=/var/www/auto-articles/.env
ExecStart=/var/www/auto-articles/.venv/bin/gunicorn app:app \
  --bind 127.0.0.1:8000 \
  --workers 2 \
  --threads 4 \
  --timeout 180 \
  --graceful-timeout 30 \
  --max-requests 500 \
  --max-requests-jitter 50
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
