# Backend environment template (safe defaults; no secrets committed)
#
# Copy to `backend/.env` on your machine/VPS and fill in real values:
#   cp backend/.env.example backend/.env

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# Do NOT set to 1 for normal local dev against Atlas/production data — it forces repo
# data/*.json only and ignores MONGODB_URI. Omit or use FORCE_JSON_STORAGE=0.
# FORCE_JSON_STORAGE=0

# -----------------------------------------------------------------------------
# Security (production checklist)
# -----------------------------------------------------------------------------
# JWT signing secret — MUST be a long random string in production (32+ characters).
SECRET_KEY=dev-insecure-change-me

# Token lifetimes (seconds)
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# CORS (comma-separated origins). In production, list only trusted browser origins (your frontend URLs).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cookie flags for auth cookies — set COOKIE_SECURE=true when the API is served over HTTPS.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# Reverse proxy (nginx / load balancer)
# -----------------------------------------------------------------------------
# Long-running API routes (article generation, WordPress publish, bulk upload) need proxy_read_timeout
# and proxy_send_timeout of at least 600s so the edge does not close before the browser (see frontend LONG_API_TIMEOUT_MS).

# -----------------------------------------------------------------------------
# Production deployment hints (set ENVIRONMENT=production)
# -----------------------------------------------------------------------------
# - Set SECRET_KEY to a cryptographically random value; never commit it.
# - Set COOKIE_SECURE=true and enforce HTTPS at the load balancer or reverse proxy.
# - Restrict CORS_ORIGINS to your real frontend domain(s); remove localhost if unused.
# - Set ENVIRONMENT=production to disable public /docs and /openapi.json exposure.
# - Use ENABLE_SCHEDULER=0 when running multiple API replicas unless only one runs the scheduler.
# - Configure MongoDB (MONGODB_URI) and any Postgres/Redis URLs required by your deployment.

# -----------------------------------------------------------------------------
# OpenAI (required for generation features)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Extra forbidden phrases in generated articles (comma-separated). Built-in defaults always apply
# (e.g. AEO-Optimized, AI suggested keywords). Example:
# GENERATION_BANNED_PHRASES=For ChatGPT,People Also Ask block
# GENERATION_BANNED_PHRASES=

# Scheduler (in-process loop; prefer ENABLE_SCHEDULER=0 in multi-worker production unless one dedicated worker runs jobs)
ENABLE_SCHEDULER=1
