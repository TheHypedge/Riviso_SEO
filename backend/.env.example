# Backend environment template (safe defaults; no secrets committed)
#
# Copy to `backend/.env` on your machine/VPS and fill in real values:
#   cp backend/.env.example backend/.env

ENVIRONMENT=development

# JWT signing secret (set a long random string in production)
SECRET_KEY=dev-insecure-change-me

# Token lifetimes (seconds)
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# CORS (comma-separated). For split hosting, include your deployed frontend origin(s).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cookie flags for auth cookies (set secure=true behind HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# OpenAI (required for generation)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Scheduler (in-process loop; keep off on VPS unless you want the worker here)
ENABLE_SCHEDULER=0
